.env
.env.local
.DS_Store
*.log
__pycache__/
*.pyc
.vscode/
.idea/
node_modules/
.vercel

# Bsky engagement watermark — per-Mini state, gitignored to avoid push conflicts
data/engage_state.json

# Cat-signal dedup state — per-Mini, ephemeral
data/cat_signal_state.json

# Bsky post log — per-Mini, append-only audit trail
data/post_log.jsonl

# Engagement snapshots captured by cleanup_bsky just before delete — per-Mini
data/post_engagement.jsonl

# Reflection output: persona + topic multipliers, regenerated nightly
data/voice_weights.json

# In-the-wild engagement state — daily cap + per-handle dedup
data/wild_state.json

# Throwback dedup — last 100 archive files we've resurfaced
data/throwback_state.json

# Tumblr like-loop state — per-Mini, daily cap + dedup
data/like_state.json

# Tumblr reblog state — per-Mini, dedup + cooldown
data/reblog_state.json

# Debug artifacts written when a gen returns non-HTML — runtime-only, must
# not be tracked or they block subsequent rebase pulls on the Mini
data/last_bad_output.txt
data/last_bad_prompt.txt

# Social poster images — ephemeral. Posted to bsky/tumblr (both wiped nightly),
# then never needed again. Generated fresh each gen; not worth committing.
archive/social/

# Cabinet thumbnails — now hosted on Vercel Blob (off-repo). Generated locally as
# a transient PNG each gen (kept as the social-post fallback), uploaded as WebP.
archive/thumbs/

# Per-gen run log — one JSON line per gen (outcomes, retries, post status).
# Per-Mini observability for the nightly digest; not worth committing.
data/runs.jsonl


# Per-worktree harness state (scheduled_tasks.lock etc.)
.claude/

# Agent-CLI pointer (symlink → CLAUDE.md, local convenience). Untracked on
# purpose: everything tracked in this repo deploys to outbox.cafe as a public
# file, and the Mini's gen cron commits with `git add -A`.
/AGENTS.md
