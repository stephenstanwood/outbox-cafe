# Bsky engagement watermark — per-Mini state, gitignored to avoid push conflicts
data/engage_state.json

# Cat-signal dedup state — per-Mini, ephemeral
data/cat_signal_state.json

# Bsky post log — per-Mini, append-only audit trail
data/post_log.jsonl

# Engagement snapshots captured by cleanup_bsky just before delete — per-Mini
data/post_engagement.jsonl

# Reflection output: persona + topic multipliers, regenerated nightly
data/voice_weights.json

# In-the-wild engagement state — daily cap + per-handle dedup
data/wild_state.json

# Throwback dedup — last 100 archive files we've resurfaced
data/throwback_state.json

# Debug artifact written when a gen returns non-HTML — runtime-only, must
# not be tracked or it blocks subsequent rebase pulls on the Mini
data/last_bad_output.txt


# Per-worktree harness state (scheduled_tasks.lock etc.)
.claude/
